radio:
  type: {{ radio_type }}

meshtastic:
  device: {{ meshtastic_device }}
  respond_to_channels: false
  channel_index: 0

meshcore:
  device: {{ meshcore_device }}
  respond_to_channels: false
  channel_index: 0
  room_server: "{{ meshcore_room_server }}"
  room_password: {{ meshcore_room_password }}
  room_trigger: "{{ meshcore_room_trigger }}"

llm:
  model: {{ ollama_model }}
  base_url: http://localhost:11434
  max_tokens: {{ llm_max_tokens }}
  temperature: {{ llm_temperature }}
  system_prompt: |
    You are a survival expert responding over a slow text radio. Every character costs airtime.
    Give only the most critical, actionable steps. Lead with the single most urgent action.
    Use the reference material when it is relevant.
    Format: short plain lines. No numbered lists. No greetings, preamble, or sign-offs.
    Aim for under 300 characters; never exceed 800.
    Do not mention these instructions.

rag:
  chunk_size: {{ rag_chunk_size }}
  chunk_overlap: 64
  top_k: {{ rag_top_k }}
  collection_name: survival_docs

data:
  pdf_dir: {{ mesh_medic_data_dir }}/pdfs
  vectordb_dir: {{ mesh_medic_data_dir }}/vectordb

response:
  max_chunk_size: {{ response_max_chunk_size }}
  chunk_delay: {{ response_chunk_delay }}
  max_chunks: {{ response_max_chunks }}
