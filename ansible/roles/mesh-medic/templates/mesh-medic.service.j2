[Unit]
Description=Mesh Medic — Meshtastic LLM Survival Assistant
After=network.target ollama.service
Requires=ollama.service

[Service]
Type=simple
User={{ mesh_medic_user }}
WorkingDirectory={{ mesh_medic_install_dir }}
ExecStart={{ mesh_medic_install_dir }}/venv/bin/python -m src.main
Environment=HF_HOME={{ mesh_medic_data_dir }}/models
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths={{ mesh_medic_install_dir }} {{ mesh_medic_data_dir }}
Restart=on-failure
RestartSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=mesh-medic

[Install]
WantedBy=multi-user.target
